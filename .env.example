# ─────────────────────────────────────────────────
# Bouclier SaaS — Environment Variables
# Copy to .env and fill in your values
# cp .env.example .env
# ─────────────────────────────────────────────────

# ── PORT CONFIGURATION ─────────────────────────
FRONTEND_PORT=3002
BACKEND_PORT=8005
TOOLS_PORT=8100

# ── DATABASE ───────────────────────────────────
DB_USER=postgres
DB_PASS=change_this_password
DB_NAME=shield_db
DB_PORT=5432

# ── REDIS ──────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── AUTH / SECURITY ────────────────────────────
NEXTAUTH_SECRET=generate_random_64_char_secret_openssl_rand_hex_32
NEXTAUTH_URL=http://localhost:3002
JWT_SECRET=change_me_jwt_secret
TOOLS_API_SECRET=change_me_tools_secret
TOOLS_API_KEY=BOUCLIER_ALPHA_SESSION_2026

# ── OFFENSIVE TOOLS ────────────────────────────
ALLOW_EXTERNAL_TARGETS=true
ALLOW_PUBLIC_TARGETS=1
SAFE_MODE=false
OFFENSIVE_MODE=true
MAX_SCAN_SCOPE=10.0.0.0/24

# ── LLM (Ollama local par défaut) ──────────────
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=llama3.2:3b
LLM_TIMEOUT=30

# ── API KEYS (optionnel — laisser vide pour Ollama) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── NVIDIA API (remplace Ollama si renseigné) ──
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://integrate.api.nvidia.com/v1
# LLM_MODEL=meta/llama-3.1-70b-instruct

# ── SYSTEM ─────────────────────────────────────
NODE_ENV=production
DOMAIN=localhost
PYTHONUNBUFFERED=1
