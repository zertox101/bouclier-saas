#!/usr/bin/env python3
"""Build source inventory (checklist.json) for a target directory.

Usage: raptor-build-checklist <target> <output_dir>

Produces checklist.json with files, functions, globals, SLOC, and SHA-256
hashes. Always rehashes files on disk. Unchanged files reuse their old
parsed entries (including coverage marks); changed files are re-parsed
and their coverage marks cleared.
"""
import sys
from pathlib import Path

# ─── trust-marker check (do not import; inline by design) ───
import os
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))


def main():
    # Use argparse so unknown --flags raise instead of silently
    # being filtered out. Pre-fix `[a for a in sys.argv[1:]
    # if not a.startswith('--')]` discarded EVERY --flag without
    # logging which ones got dropped. If an operator passed
    # `--out /custom` thinking it'd override the positional
    # output_dir, the flag was silently ignored and the
    # positional defaulted (or raised "Usage" if positional
    # was missing). Confusing failure mode — the operator's
    # explicit intent didn't take effect with no breadcrumb.
    import argparse
    ap = argparse.ArgumentParser(
        prog="raptor-build-checklist",
        description="Build a per-file checklist for exploitability validation.",
    )
    ap.add_argument("target", help="Target source root.")
    ap.add_argument("output_dir", help="Where to write the checklist.")
    # Tolerate well-known launcher flags that may be passed
    # through but aren't relevant here. parse_known_args puts
    # them in `_extras`; we don't act on them but document
    # their presence so future readers see why we accept them.
    parsed, _extras = ap.parse_known_args(sys.argv[1:])
    target = parsed.target
    output_dir = parsed.output_dir

    if not Path(target).exists():
        print(f"ERROR: target not found: {target}", file=sys.stderr)
        sys.exit(1)

    Path(output_dir).mkdir(parents=True, exist_ok=True)

    from packages.exploitability_validation import build_checklist
    checklist = build_checklist(target, output_dir)

    total = checklist.get("total_files", 0)
    items = checklist.get("total_items", 0)
    sloc = checklist.get("total_sloc", 0)
    print(f"Checklist: {total} files, {items} items, {sloc} SLOC")


if __name__ == "__main__":
    main()
