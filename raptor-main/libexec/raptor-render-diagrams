#!/usr/bin/env python3
"""Render Mermaid diagrams from JSON outputs in a directory.

Usage: raptor-render-diagrams <output_dir> [--target <name>] [--force]
"""
import sys
from pathlib import Path

# ─── trust-marker check (do not import; inline by design) ───
import os
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))


def main():
    if len(sys.argv) < 2:
        print("Usage: raptor-render-diagrams <output_dir> [--target <name>] [--force]",
              file=sys.stderr)
        sys.exit(1)

    out_dir = Path(sys.argv[1])
    # --force opts into clobbering an existing diagrams.md. Without it,
    # a re-render refuses so an operator's hand-edits aren't silently
    # overwritten. Ported from the now-deleted generate_diagram.py
    # (commit a94fd36b) which had the protection but was never the
    # live entry point.
    force = "--force" in sys.argv
    target = None
    if "--target" in sys.argv:
        idx = sys.argv.index("--target")
        # Reject `--target` without a value. Pre-fix the trailing
        # `--target` (no following arg) was silently treated as
        # "no target" — operator typo went undetected. Worse, an
        # operator who passed `raptor-render-diagrams out --target`
        # then later flags (e.g. `--target --some-flag`) silently
        # consumed `--some-flag` as the target VALUE, producing
        # nonsensical diagram headers.
        if idx + 1 >= len(sys.argv):
            print(
                "ERROR: --target requires a value (e.g. --target my-app)",
                file=sys.stderr,
            )
            sys.exit(1)
        target = sys.argv[idx + 1]
        # Reject value that itself looks like a flag — same
        # protection against accidental flag-as-value capture.
        if target.startswith("--"):
            print(
                f"ERROR: --target value {target!r} looks like a flag; "
                f"--target requires a non-flag value",
                file=sys.stderr,
            )
            sys.exit(1)

    if not out_dir.exists():
        print(f"ERROR: directory not found: {out_dir}", file=sys.stderr)
        sys.exit(1)

    # Pre-flight overwrite check — render_and_write writes to
    # out_dir/diagrams.md unconditionally; refuse here unless --force.
    default_out = out_dir / "diagrams.md"
    if default_out.exists() and not force:
        print(
            f"ERROR: {default_out} already exists. Pass --force to overwrite.",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        from packages.diagram import render_and_write
        output_file = render_and_write(out_dir, target=target)
        print(f"Diagrams: {output_file}")
    except Exception as e:
        print(f"Diagram error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
