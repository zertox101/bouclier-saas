#!/usr/bin/env python3
"""Coverage query and update tool.

Usage:
  raptor-coverage-summary [<dir>] [--detailed]          Show coverage summary
  raptor-coverage-summary [<dir>] --store               Show persistent-store view
                                                        (category/depth + LLM-review gap)
  raptor-coverage-summary [<dir>] --gaps                List unreviewed items
  raptor-coverage-summary [<dir>] --mark <file:item>    Mark item(s) as reviewed
  raptor-coverage-summary [<dir>] --mark-file <json>    Mark functions from JSON file
  raptor-coverage-summary [<dir>] --unmark <file:item>  Remove item from reviewed
  raptor-coverage-summary [<dir>] --import <path>       Ingest external runtime
      [--format gcov|lcov|coverage.py] [--tool <label>] coverage (gcov/lcov/
                                                        coverage.py) into the store

If <dir> is omitted, uses the active project.
Accepts: project output dir, run dir, target path, or project name.
"""
import sys
from pathlib import Path

# ─── trust-marker check (do not import; inline by design) ───
import os
if not (os.environ.get("CLAUDECODE")
        or os.environ.get("_RAPTOR_TRUSTED")):
    sys.stderr.write(
        f"{sys.argv[0]}: internal dispatch script.\n"
        "  Run via 'bin/raptor' instead.\n"
        "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass.\n"
    )
    sys.exit(2)
# ─── end trust-marker check ─────────────────────────────────

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))


def _is_project_dir(d: Path) -> bool:
    if not (d / "checklist.json").exists():
        return False
    for child in d.iterdir():
        if child.is_dir() and (child / ".raptor-run.json").exists():
            return True
    return False


def _is_run_dir(d: Path) -> bool:
    """Run-dir discriminator.

    Pre-fix the predicate matched any directory with EITHER
    `.raptor-run.json` OR `checklist.json` — but `checklist.json`
    is ALSO present in project directories (project-level
    checklist). The bug was masked at the call site by check
    order: `_is_project_dir(d)` is tested FIRST in
    `_resolve_dir`, so a project dir was correctly classified
    despite this predicate claiming True.

    "Saved by check order" is fragile — any future caller that
    skips the project-dir check (or reorders) hits the
    misclassification. Tighten the predicate to require the
    run-specific marker (`.raptor-run.json`) AND the absence of
    a project-level marker. `checklist.json` alone is no longer
    sufficient because it's ambiguous between project and run
    dirs.
    """
    if not (d / ".raptor-run.json").exists():
        return False
    # Negative check: project-dir marker should NOT be present.
    # `_is_project_dir` is the canonical project-dir check; if
    # the dir has both markers, it's a project dir, not a run.
    if _is_project_dir(d):
        return False
    return True


def _resolve_dir(path_arg: str):
    """Resolve to (Project, None) or (None, run_dir) or (None, None)."""
    from core.project.project import Project, ProjectManager

    target_dir = Path(path_arg).resolve()

    if target_dir.exists() and _is_project_dir(target_dir):
        return Project(name="", target="", output_dir=str(target_dir)), None

    if target_dir.exists() and _is_run_dir(target_dir):
        return None, target_dir

    # Try project name
    try:
        mgr = ProjectManager()
        p = mgr.load(path_arg)
        if p:
            return p, None
    except Exception:
        pass

    # Try target path → project
    try:
        mgr = ProjectManager()
        project = mgr.find_project_for_target(str(target_dir))
        if project:
            return project, None
    except Exception:
        pass

    if target_dir.exists():
        return None, None
    return None, None


def _resolve_active_project():
    try:
        from core.project.project import ProjectManager
        mgr = ProjectManager()
        name = mgr.get_active()
        if name:
            return mgr.load(name)
    except Exception:
        pass
    return None


def _store_inputs(args):
    """Resolve (checklist, run_dirs, store_path, annotations_base)."""
    from core.json import load_json

    project = run_dir = None
    if args:
        project, run_dir = _resolve_dir(args[0])
        if not project and not run_dir:
            d = Path(args[0])
            if d.exists():
                run_dir = d
    else:
        project = _resolve_active_project()

    if project:
        base = Path(project.output_dir)
        try:
            run_dirs = list(project.get_run_dirs(sweep=False))
        except Exception:
            run_dirs = []
        return (load_json(base / "checklist.json"), run_dirs,
                base / "coverage.json", base / "annotations")
    if run_dir:
        return (load_json(run_dir / "checklist.json"), [run_dir],
                run_dir / "coverage.json", run_dir / "annotations")
    return None, [], None, None


def _cmd_gaps(view):
    """Print the LLM-review gap — reviewable units (function/top_level) with no
    LLM review. Globals/macros/typedefs/glue are excluded by design."""
    if not view:
        print("No coverage data.")
        return
    gaps = view.get("llm_gap_functions", [])
    if not gaps:
        print("All reviewable items examined by an LLM.")
        return
    print(f"{len(gaps)} item{'s' if len(gaps) != 1 else ''} with no LLM review:")
    for g in gaps:
        print(f"  {g['file']}:{g['function']}")


def _cmd_mark(mark_targets, run_dir):
    """Mark items as reviewed in the coverage record."""
    if not run_dir:
        print("ERROR: cannot determine run directory for --mark.", file=sys.stderr)
        print("Specify a run directory explicitly.", file=sys.stderr)
        sys.exit(1)

    from core.coverage.record import load_records, write_record

    # Load existing LLM record or create new
    records = load_records(run_dir)
    llm_record = None
    for r in records:
        if r.get("tool") == "llm":
            llm_record = r
            break

    if not llm_record:
        from datetime import datetime, timezone
        llm_record = {
            "tool": "llm",
            "timestamp": datetime.now(timezone.utc).isoformat(),
            "files_examined": [],
            "functions_analysed": [],
        }

    existing_funcs = {
        (fa.get("file"), fa.get("function"))
        for fa in llm_record.get("functions_analysed", [])
    }

    added = 0
    for target in mark_targets:
        if ":" not in target:
            print(f"WARNING: skipping '{target}' (expected file:function)", file=sys.stderr)
            continue
        file_path, func_name = target.rsplit(":", 1)
        if (file_path, func_name) not in existing_funcs:
            llm_record.setdefault("functions_analysed", []).append(
                {"file": file_path, "function": func_name}
            )
            existing_funcs.add((file_path, func_name))
            added += 1
    # Marking a function records function-level review only — it must NOT add
    # the file to files_examined (which is the whole-file "tool scanned this
    # file" signal; the store would otherwise mark the entire file reviewed).
    write_record(run_dir, llm_record, tool_name="llm")
    print(f"Marked {added} item{'s' if added != 1 else ''} as reviewed in {run_dir.name}")


def _cmd_unmark(unmark_targets, run_dir):
    """Remove functions from the LLM coverage record."""
    if not run_dir:
        print("ERROR: cannot determine run directory for --unmark.", file=sys.stderr)
        sys.exit(1)

    from core.coverage.record import load_records, write_record

    records = load_records(run_dir)
    llm_record = None
    for r in records:
        if r.get("tool") == "llm":
            llm_record = r
            break

    if not llm_record:
        print("No LLM coverage record found.")
        return

    to_remove = set()
    for target in unmark_targets:
        if ":" not in target:
            print(f"WARNING: skipping '{target}' (expected file:function)", file=sys.stderr)
            continue
        file_path, func_name = target.rsplit(":", 1)
        to_remove.add((file_path, func_name))

    original = len(llm_record.get("functions_analysed", []))
    llm_record["functions_analysed"] = [
        fa for fa in llm_record.get("functions_analysed", [])
        if (fa.get("file"), fa.get("function")) not in to_remove
    ]
    removed = original - len(llm_record["functions_analysed"])

    write_record(run_dir, llm_record, tool_name="llm")
    print(f"Removed {removed} item{'s' if removed != 1 else ''} from reviewed in {run_dir.name}")


def _cmd_import(import_path, fmt, tool, args):
    """Ingest external runtime coverage (gcov/lcov/coverage.py) into the target's
    durable store. The positional <dir> (if any) resolves the project/run store;
    --import names the coverage artifact. Persists under the store lock."""
    from core.coverage.importer import import_runtime
    from core.coverage.store import CoverageStore, coverage_store_lock

    if not Path(import_path).exists():
        print(f"ERROR: coverage path not found: {import_path}", file=sys.stderr)
        sys.exit(1)
    checklist, _run_dirs, store_path, _ann = _store_inputs(args)
    if not checklist or not store_path:
        print("ERROR: no inventory (checklist.json) for the target — runtime "
              "coverage needs a project/run with an inventory. Specify a project "
              "or run dir.", file=sys.stderr)
        sys.exit(1)
    with coverage_store_lock(store_path):
        store = CoverageStore(store_path)
        n = import_runtime(store, import_path, checklist, fmt=fmt, tool=tool)
        store.save()
    print(f"Imported {n} runtime coverage range(s) from {import_path} -> {store_path}")


def main():
    argv = sys.argv[1:]

    # --import <path> [--format <fmt>] [--tool <label>]: ingest external runtime
    # coverage. Extract the flag+value pairs up front so the path value isn't
    # later mistaken for a positional <dir>.
    def _take_opt(flag, av):
        if flag in av:
            i = av.index(flag)
            if i + 1 < len(av):
                return av[i + 1], av[:i] + av[i + 2:]
        return None, av
    import_path, argv = _take_opt("--import", argv)
    import_fmt, argv = _take_opt("--format", argv)
    import_tool, argv = _take_opt("--tool", argv)

    detailed = "--detailed" in argv
    show_gaps = "--gaps" in argv
    # `--store` is the default behaviour now; accepted (and stripped as a
    # flag) for back-compat, no separate branch.

    # Extract --mark, --mark-file, --unmark targets
    mark_targets = []
    unmark_targets = []
    if "--mark-file" in argv:
        idx = argv.index("--mark-file")
        if idx + 1 < len(argv):
            mark_file = Path(argv[idx + 1])
            if not mark_file.exists():
                print(f"ERROR: file not found: {mark_file}", file=sys.stderr)
                sys.exit(1)
            from core.json import load_json
            entries = load_json(mark_file)
            if not isinstance(entries, list):
                print("ERROR: mark file must be a JSON array of {file, item} objects",
                      file=sys.stderr)
                sys.exit(1)
            for e in entries:
                f = e.get("file", "")
                name = e.get("item") or e.get("function") or e.get("global") or e.get("macro", "")
                if f and name:
                    mark_targets.append(f"{f}:{name}")
            argv = argv[:idx] + argv[idx + 2:]
    # Process --mark / --unmark in a SINGLE pass so flag order
    # doesn't matter. Pre-fix the if-else sequence below
    # processed `--mark` first then truncated `argv` to
    # `argv[:idx_of_mark]`; if the operator passed
    # `--mark a b --unmark c`, the truncation at step 1
    # discarded everything from `--mark` onward — including
    # the `--unmark c` that came AFTER. Subsequent
    # `if "--unmark" in argv:` then saw a truncated argv
    # WITHOUT --unmark and silently no-op'd. The operator's
    # explicit unmark request was dropped.
    #
    # Two-pass: collect all --mark/--unmark slices first,
    # then do a single truncation at the smallest index so
    # downstream positional-arg extraction sees the same
    # cleaned-up argv it expected.
    def _slurp_after(flag: str) -> list:
        if flag not in argv:
            return []
        i = argv.index(flag)
        out = []
        for a in argv[i + 1:]:
            if a.startswith("--"):
                break
            out.append(a)
        return out
    mark_extra = _slurp_after("--mark")
    unmark_extra = _slurp_after("--unmark")
    mark_targets.extend(mark_extra)
    unmark_targets.extend(unmark_extra)
    # Now truncate argv at the FIRST appearance of either flag
    # so positional-arg extraction below isn't confused by the
    # mark/unmark tokens.
    cut_indices = [
        argv.index(f) for f in ("--mark", "--unmark") if f in argv
    ]
    if cut_indices:
        argv = argv[: min(cut_indices)]

    # Remaining positional args (after removing flags)
    args = [a for a in argv if not a.startswith("--")]

    if mark_targets or unmark_targets:
        run_dir = None
        if args:
            _, run_dir = _resolve_dir(args[0])
            if not run_dir:
                d = Path(args[0])
                if d.exists() and _is_run_dir(d):
                    run_dir = d
        if not run_dir:
            # Use most recent run from active project
            p = _resolve_active_project()
            if p:
                try:
                    dirs = p.get_run_dirs(sweep=False)
                    if dirs:
                        run_dir = dirs[0]
                except Exception:
                    pass
        if mark_targets:
            _cmd_mark(mark_targets, run_dir)
        if unmark_targets:
            _cmd_unmark(unmark_targets, run_dir)
        return

    if import_path:
        _cmd_import(import_path, import_fmt, import_tool, args)
        return

    # All report views go through the unified store-backed renderer. `--store`
    # is now the default behaviour; the flag is accepted for back-compat.
    from core.coverage.store_summary import coverage_view, render_coverage

    checklist, run_dirs, store_path, annotations_base = _store_inputs(args)

    if show_gaps:
        _cmd_gaps(coverage_view(run_dirs, checklist, store_path, annotations_base))
        return

    report = render_coverage(
        run_dirs, checklist, store_path, annotations_base, detailed=detailed)
    if not report:
        print("No coverage data (missing checklist.json or coverage records).")
        return
    print(report)


if __name__ == "__main__":
    main()
