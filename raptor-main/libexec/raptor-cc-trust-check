#!/usr/bin/env bash
#
# raptor-cc-trust-check — pre-flight check for dangerous Claude Code config
#                        in the target repo before `exec claude`.
#
# Invoked by bin/raptor before launching Claude Code. Delegates to
# core/security/cc_trust.py so the same logic runs from the launcher and
# from Python entry points (raptor_agentic.py, build_detector.py).
#
# Usage:
#   libexec/raptor-cc-trust-check [--dry-run] [--trust] <target_path>
#
# --trust: set the module-level trust override before scanning. bin/raptor
#          passes this when the user gave --trust-repo. Not driven by env
#          var — deliberately, to close an injection path where a target
#          repo's settings.json `env` dict could forge the override.
#
# --dry-run: still scan and print findings, but always exit 0. Useful for
#   debugging ("what would this flag?") without actually blocking the caller.
#
# Exit codes:
#   0  no target, target safe, --trust, or --dry-run
#   2  target has dangerous CC config (caller should not launch)
#   3  internal error (missing python, module import failure)
#
# Security note: the target repo may contain a hostile `core/` directory or
# other Python modules that could shadow RAPTOR's imports. The Python child
# below runs with `cwd=RAPTOR_DIR` and `-I` (isolated: ignore env/user site
# and don't add cwd to sys.path) so only files under RAPTOR_DIR — passed in
# via an explicit sys.path entry inside the script — can be imported.

set -euo pipefail

# ─── trust-marker check (do not source; inline by design) ───
if [ -z "${CLAUDECODE:-}" ] && [ -z "${_RAPTOR_TRUSTED:-}" ]; then
    echo "$0: internal dispatch script." >&2
    echo "  Run via 'bin/raptor' instead." >&2
    echo "  Tests / power users: set _RAPTOR_TRUSTED=1 to bypass." >&2
    exit 2
fi
# ─── end trust-marker check ─────────────────────────────────

DRY_RUN=0
TRUST=0
TARGET=""
TARGET_SET=0
# Accept --dry-run / --trust in any position; first positional is TARGET;
# unknown flags and extra positionals are rejected loudly so typos don't
# silently change which path we check.
#
# Honour the `--` terminator: anything after `--` is treated as a
# positional argument regardless of whether it starts with `-`.
# bin/raptor (cluster 585) now passes `--` before the target path
# so a target starting with `-` (rare but legitimate; e.g. a checkout
# named `--branch-foo/`) doesn't trigger "unknown flag" + exit 2.
# Pre-fix the loop's `case ... -*) ...` arm caught dash-prefixed
# paths and exited 3, which the launcher mis-reported as
# "refusing to launch".
#
# Also normalise `--trust=` / `--dry-run=` value forms for
# operator ergonomics: pre-fix `--trust=1` was treated as an
# unknown flag (the case arm matched only the bare form). Accept
# the `=value` form too — any non-empty/non-"0"/non-"false"
# value enables.
end_of_flags=0
for arg in "$@"; do
    if [ "$end_of_flags" = "1" ]; then
        if [ "$TARGET_SET" = "0" ]; then
            TARGET="$arg"
            TARGET_SET=1
        else
            echo "raptor-cc-trust-check: unexpected extra argument: $arg" >&2
            echo "  usage: raptor-cc-trust-check [--dry-run] [--trust] [--] <target_path>" >&2
            exit 3
        fi
        continue
    fi
    case "$arg" in
        --)
            end_of_flags=1
            ;;
        --dry-run|--dry-run=*)
            v="${arg#*=}"
            # bare `--dry-run` (no `=`): v == "--dry-run" — treat as enable.
            # `--dry-run=0` / `--dry-run=false` — disable.
            if [ "$arg" = "--dry-run" ] || [ -z "$v" ] || [ "$v" = "--dry-run" ]; then
                DRY_RUN=1
            elif [ "$v" = "0" ] || [ "$v" = "false" ] || [ "$v" = "no" ]; then
                DRY_RUN=0
            else
                DRY_RUN=1
            fi
            ;;
        --trust|--trust=*)
            v="${arg#*=}"
            if [ "$arg" = "--trust" ] || [ -z "$v" ] || [ "$v" = "--trust" ]; then
                TRUST=1
            elif [ "$v" = "0" ] || [ "$v" = "false" ] || [ "$v" = "no" ]; then
                TRUST=0
            else
                TRUST=1
            fi
            ;;
        -*)
            echo "raptor-cc-trust-check: unknown flag: $arg" >&2
            echo "  usage: raptor-cc-trust-check [--dry-run] [--trust] [--] <target_path>" >&2
            exit 3
            ;;
        *)
            if [ "$TARGET_SET" = "0" ]; then
                TARGET="$arg"
                TARGET_SET=1
            else
                echo "raptor-cc-trust-check: unexpected extra argument: $arg" >&2
                echo "  usage: raptor-cc-trust-check [--dry-run] [--trust] [--] <target_path>" >&2
                exit 3
            fi
            ;;
    esac
done

if [ -z "$TARGET" ]; then
    exit 0
fi

# Resolve symlinks to find the real script location — matches bin/raptor's pattern
# so packagers can safely symlink this wrapper from PATH locations.
#
# Hop bound: pre-fix `while [ -L "$SCRIPT" ]` had no termination
# guard. A symlink cycle (A → B → A) — easy to create accidentally
# during install scripting, or maliciously via a poisoned ~/bin
# layout — would loop forever. POSIX `realpath -e` would normally
# detect ELOOP, but we can't rely on it (BSD vs GNU realpath differ
# and the canonical pattern across raptor/* is the manual loop).
# 32 hops matches Linux's MAXSYMLINKS (8 nested chains × redundancy);
# real package layouts rarely exceed 2-3 hops.
SCRIPT="$0"
_symhops=0
while [ -L "$SCRIPT" ]; do
    _symhops=$((_symhops + 1))
    if [ "$_symhops" -gt 32 ]; then
        echo "raptor-cc-trust-check: symlink hop limit exceeded resolving $0" >&2
        echo "  (likely a symlink cycle; refusing to resolve further)" >&2
        exit 3
    fi
    DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"
    SCRIPT="$(readlink "$SCRIPT")"
    [[ "$SCRIPT" != /* ]] && SCRIPT="$DIR/$SCRIPT"
done
unset _symhops
RAPTOR_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

if ! command -v python3 >/dev/null 2>&1; then
    echo "raptor-cc-trust-check: python3 not found" >&2
    exit 3
fi

# -I = isolated mode: strips PYTHONPATH and PYTHONHOME, doesn't add user site,
#      and does not prepend cwd to sys.path. Prevents the target repo from
#      smuggling a shadowing `core/` via PYTHONPATH, ~/.local, or cwd.
# Pre-fix `cd "$RAPTOR_DIR"` failed silently if RAPTOR_DIR
# became invalid (operator running from a deleted dir, race
# with directory removal, broken symlink). Subsequent
# `python3 -I - "$RAPTOR_DIR" ...` then ran from the OLD
# cwd with RAPTOR_DIR pointing somewhere that the
# `sys.path.insert(0, raptor_dir)` line couldn't actually
# read from — the import inside the heredoc raised
# ModuleNotFoundError, the script exited rc=1, and per
# batch 586 we'd treat that as "failing closed" — correct
# behaviour but with an unhelpful "undocumented exit code
# 1" message. Catch the cd failure here with a clear
# diagnostic instead.
if ! cd "$RAPTOR_DIR" 2>/dev/null; then
    echo "raptor-cc-trust-check: cannot cd into RAPTOR_DIR=$RAPTOR_DIR" >&2
    echo "  (RAPTOR_DIR resolved at startup but is no longer accessible — refusing to run trust check)" >&2
    exit 3
fi
set +e
python3 -I - "$RAPTOR_DIR" "$TARGET" "$TRUST" <<'PY'
import sys
raptor_dir, target, trust_arg = sys.argv[1], sys.argv[2], sys.argv[3]
sys.path.insert(0, raptor_dir)
try:
    from core.security.cc_trust import check_repo_claude_trust, set_trust_override
except Exception as e:
    print(f"raptor-cc-trust-check: import failed: {e}", file=sys.stderr)
    sys.exit(3)

if trust_arg == "1":
    set_trust_override(True)
blocked = check_repo_claude_trust(target)
sys.exit(2 if blocked else 0)
PY
rc=$?
set -e

# --dry-run: surface findings but never block the caller.
if [ "$DRY_RUN" = "1" ] && [ "$rc" = "2" ]; then
    echo "raptor-cc-trust-check: --dry-run suppressed the block (would have exited 2)" >&2
    exit 0
fi

# Fail-closed on undocumented exit codes. The Python checker
# documents three exit codes: 0 (clean), 2 (blocked), 3 (error
# during scan). Any other code (1 from interpreter crash, 137
# from OOM, 139 from segfault, 99 from a future-added code we
# haven't taught the launcher about) is undefined behaviour
# from the trust-check perspective.
#
# Pre-fix `exit "$rc"` propagated whatever the Python returned.
# The launcher's downstream wrapper (bin/raptor) only treats
# rc=2 as "blocked" and rc=0 as "clean"; everything else
# silently fell through to the "proceed" path. So a corrupted
# Python that crashed with rc=137 looked like rc=137 to the
# launcher, which interpreted it as "unknown — proceed" — the
# trust check effectively didn't run. SECURITY BUG: an
# attacker who can OOM the trust-check process gets to bypass
# the trust check entirely.
#
# Map any non-{0,2,3} code to rc=2 (blocked). Better to fail
# noisy than silently-bypass the security gate.
case "$rc" in
    0|2|3)
        ;;
    *)
        echo "raptor-cc-trust-check: undocumented exit code $rc — failing closed (treating as 'blocked')" >&2
        rc=2
        ;;
esac
exit "$rc"
